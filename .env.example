# Application
APP_NAME="Mordecai AI"
NODE_ENV=development
PORT=3000
API_VERSION=v1
VALIDATE_ENV=false
DB_ENABLED=true

# Database
DB_NAME=your_db
DB_USER=your_user
DB_PASSWORD=your_password
DB_HOST=your_host
DB_PORT=5432
DB_SSL=true
DB_SYNC_MODE=false

# Auth cookies
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false

# CORS
CORS_ORIGIN=http://localhost:8080
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# AWS / S3
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
S3_BUCKET_NAME=your_bucket

# Cognito
COGNITO_REGION=us-east-2
COGNITO_USER_POOL_ID=us-east-2_xxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=https://your-domain.auth.us-east-2.amazoncognito.com
COGNITO_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/callback
COGNITO_OAUTH_SCOPES=openid email profile
COGNITO_FRONTEND_REDIRECT_URI=http://localhost:8080/auth/callback
COGNITO_OAUTH_PROMPT=select_account

# Twilio stream engine selector
# `realtime`: OpenAI Realtime WS speech-to-speech
# `pipeline`: STT + LLM + TTS pipeline
# `eleven_register`: Twilio webhook asks ElevenLabs register_call for TwiML
TWILIO_ENGINE=realtime

# OpenAI Realtime (used when TWILIO_ENGINE=realtime)
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_REALTIME_INSTRUCTIONS=You are a debt negotiation agent for Mordecai AI.
OPENAI_REALTIME_OPENING_PROMPT=Greet the debtor briefly and mention the 5000 dollars balance.

# ElevenLabs (used when TWILIO_ENGINE=eleven_register)
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: used in ElevenLabs UI as webhook destination
ELEVENLABS_POST_CALL_WEBHOOK_URL=https://your-domain.com/api/v1/eleven/post-call
# Optional fallback only (preferred source is request/DB)
TWILIO_FROM_NUMBER=+12135550123
TWILIO_TO_NUMBER=+573001112233
# Optional fallback only (preferred source is request/DB)
TWILIO_DEBTOR_NAME=Andres Cristobal Sosa
TWILIO_BALANCE_AMOUNT=5000

# OpenAI (ASR + LLM + TTS)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_STT_LANGUAGE=en
OPENAI_STT_PROMPT=Keywords: balance, payment, repayment, installment, settlement, dollars, thousand, hundred, today, tomorrow, next month, yes, no.
OPENAI_STT_STREAM=true
OPENAI_LLM_MODEL=gpt-4o
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=pcm
OPENAI_TTS_SAMPLE_RATE=24000
OPENAI_LLM_SYSTEM_PROMPT=You are a debt negotiation agent for Mordecai AI.

# Audio/VAD tuning
TWILIO_STT_CHUNK_MS=700
TWILIO_STT_MIN_MS=150
TWILIO_VAD_THRESHOLD=500
TWILIO_VAD_SILENCE_MS=450
TWILIO_BARGE_IN_MS=200
TWILIO_TTS_CHUNK_MIN_CHARS=80
TWILIO_UTTERANCE_TIMEOUT_MS=450
TWILIO_ASSISTANT_DEDUP_MS=2000
TWILIO_ECHO_SUPPRESS=true
TWILIO_ECHO_SUPPRESS_MULTIPLIER=1.15
